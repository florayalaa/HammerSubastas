# Copiá este archivo a .env y completá con tus credenciales locales (no se commitea)
# Cada miembro del equipo corre su propia instancia local con su propia copia de la base
# (creada con docs/HammerSubastas.sql) y su propio login SQL.

DB_USER=tu_usuario_sql
DB_PASSWORD=tu_contraseña
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=HammerSubastas
