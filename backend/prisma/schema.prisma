generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model asistentes {
  identificador Int      @id(map: "pk_asistentes") @default(autoincrement())
  numeroPostor  Int
  cliente       Int
  subasta       Int
  clientes      clientes @relation(fields: [cliente], references: [identificador], onUpdate: NoAction, map: "fk_asistentes_clientes")
  subastas      subastas @relation(fields: [subasta], references: [identificador], onUpdate: NoAction, map: "fk_asistentes_subasta")
  pujos         pujos[]
}

model catalogos {
  identificador Int             @id(map: "pk_catalogos") @default(autoincrement())
  descripcion   String          @db.VarChar(250)
  subasta       Int?
  responsable   Int
  empleados     empleados       @relation(fields: [responsable], references: [identificador], onUpdate: NoAction, map: "fk_catalogos_empleados")
  subastas      subastas?       @relation(fields: [subasta], references: [identificador], onDelete: NoAction, onUpdate: NoAction, map: "fk_catalogos_subastas")
  itemsCatalogo itemsCatalogo[]
}

model clientes {
  identificador             Int                        @id(map: "pk_clientes")
  numeroPais                Int?
  admitido                  String?                    @db.VarChar(2)
  categoria                 String?                    @db.VarChar(10)
  verificador               Int
  asistentes                asistentes[]
  empleados                 empleados                  @relation(fields: [verificador], references: [identificador], onUpdate: NoAction, map: "fk_clientes_empleados")
  paises                    paises?                    @relation(fields: [numeroPais], references: [numero], onDelete: NoAction, onUpdate: NoAction, map: "fk_clientes_paises")
  personas                  personas                   @relation(fields: [identificador], references: [identificador], onUpdate: NoAction, map: "fk_clientes_personas")
  extra_credencialesCliente extra_credencialesCliente?
  extra_documentosCliente   extra_documentosCliente?
  extra_metodosPago         extra_metodosPago[]
  extra_solicitudesVenta    extra_solicitudesVenta[]
  extra_subastas            extra_subastas[]
  registroDeSubasta         registroDeSubasta[]
}

model duenios {
  identificador          Int                 @id(map: "pk_duenios")
  numeroPais             Int?
  verificacionFinanciera String?             @db.VarChar(2)
  verificacionJudicial   String?             @db.VarChar(2)
  calificacionRiesgo     Int?
  verificador            Int
  empleados              empleados           @relation(fields: [verificador], references: [identificador], onUpdate: NoAction, map: "fk_duenios_empleados")
  personas               personas            @relation(fields: [identificador], references: [identificador], onUpdate: NoAction, map: "fk_duenios_personas")
  productos              productos[]
  registroDeSubasta      registroDeSubasta[]
}

model empleados {
  identificador Int         @id(map: "pk_empleados")
  cargo         String?     @db.VarChar(100)
  sector        Int?
  catalogos     catalogos[]
  clientes      clientes[]
  duenios       duenios[]
  productos     productos[]
  sectores      sectores[]
}

model extra_credencialesCliente {
  cliente          Int      @id(map: "pk_extra_credencialesCliente")
  email            String   @unique(map: "uq_extra_credencialesCliente_email") @db.VarChar(200)
  passwordHash     String   @db.VarChar(500)
  estadoCredencial String   @default("pendiente", map: "DF__extra_cre__estad__3C34F16F") @db.VarChar(20)
  debeCambiarClave String   @default("si", map: "DF__extra_cre__debeC__3E1D39E1") @db.VarChar(2)
  mailEnviado      Boolean  @default(false, map: "DF__extra_cre__mailE__40058253")
  fechaRegistro    DateTime @default(now(), map: "DF__extra_cre__fecha__40F9A68C") @db.Date
  clientes         clientes @relation(fields: [cliente], references: [identificador], onUpdate: NoAction, map: "fk_extra_credencialesCliente_clientes")
}

model extra_documentosCliente {
  cliente    Int      @id(map: "pk_extra_documentosCliente")
  fotoFrente Bytes
  fotoDorso  Bytes
  clientes   clientes @relation(fields: [cliente], references: [identificador], onUpdate: NoAction, map: "fk_extra_documentosCliente_clientes")
}

model extra_metodosPago {
  identificador           Int                       @id(map: "pk_extra_metodosPago") @default(autoincrement())
  cliente                 Int
  tipo                    String                    @db.VarChar(20)
  numero                  String                    @db.VarChar(50)
  vencimiento             DateTime?                 @db.Date
  cvv                     String?                   @db.VarChar(4)
  titular                 String?                   @db.VarChar(150)
  banco                   String?                   @db.VarChar(150)
  pais                    String?                   @db.VarChar(100)
  alias                   String?                   @db.VarChar(50)
  montoGarantia           Decimal?                  @db.Decimal(18, 2)
  fotoCheque              Bytes?
  estado                  String                    @default("pendiente", map: "DF__extra_met__estad__489AC854") @db.VarChar(20)
  clientes                clientes                  @relation(fields: [cliente], references: [identificador], onUpdate: NoAction, map: "fk_extra_metodosPago_clientes")
  extra_registroDeSubasta extra_registroDeSubasta[]
}

model extra_subastas {
  identificador    Int       @id(map: "pk_extra_subastas") @default(autoincrement())
  subasta          Int
  titulo           String    @db.VarChar(200)
  descripcion      String?   @db.VarChar(500)
  fechaFin         DateTime?
  moneda           String    @default("ARS", map: "DF__extra_sub__moned__4D5F7D71") @db.VarChar(3)
  categoriaBien    String?   @db.VarChar(30)
  esColeccion      Boolean   @default(false, map: "DF__extra_sub__esCol__503BEA1C")
  clienteColeccion Int?
  clientes         clientes? @relation(fields: [clienteColeccion], references: [identificador], onDelete: NoAction, onUpdate: NoAction, map: "fk_extra_subastas_clientes")
  subastas         subastas  @relation(fields: [subasta], references: [identificador], onUpdate: NoAction, map: "fk_extra_subastas_subastas")
}

model fotos {
  identificador Int       @id(map: "pk_fotos") @default(autoincrement())
  producto      Int
  foto          Bytes
  productos     productos @relation(fields: [producto], references: [identificador], onUpdate: NoAction, map: "fk_fotos_productos")
}

model itemsCatalogo {
  identificador Int       @id(map: "pk_itemsCatalogo") @default(autoincrement())
  catalogo      Int
  producto      Int
  precioBase    Decimal   @db.Decimal(18, 2)
  comision      Decimal   @db.Decimal(18, 2)
  subastado     String?   @db.VarChar(2)
  catalogos     catalogos @relation(fields: [catalogo], references: [identificador], onUpdate: NoAction, map: "fk_itemsCatalogo_catalogos")
  productos     productos @relation(fields: [producto], references: [identificador], onUpdate: NoAction, map: "fk_itemsCatalogo_productos")
  pujos         pujos[]
}

model paises {
  numero       Int        @id(map: "pk_paises")
  nombre       String     @db.VarChar(250)
  nombreCorto  String?    @db.VarChar(250)
  capital      String     @db.VarChar(250)
  nacionalidad String     @db.VarChar(250)
  idiomas      String     @db.VarChar(150)
  clientes     clientes[]
}

model personas {
  identificador  Int              @id(map: "pk_personas") @default(autoincrement())
  documento      String           @db.VarChar(20)
  nombre         String           @db.VarChar(150)
  direccion      String?          @db.VarChar(250)
  estado         String?          @db.VarChar(15)
  foto           Bytes?
  clientes       clientes?
  duenios        duenios?
  notificaciones notificaciones[]
  subastadores   subastadores?
}

model productos {
  identificador          Int                     @id(map: "pk_productos") @default(autoincrement())
  fecha                  DateTime?               @db.Date
  disponible             String?                 @db.VarChar(2)
  descripcionCatalogo    String?                 @default("No Posee", map: "DF__productos__descr__160F4887") @db.VarChar(500)
  descripcionCompleta    String                  @db.VarChar(300)
  revisor                Int
  duenio                 Int
  seguro                 String?                 @db.VarChar(30)
  extra_solicitudesVenta extra_solicitudesVenta?
  fotos                  fotos[]
  itemsCatalogo          itemsCatalogo[]
  duenios                duenios                 @relation(fields: [duenio], references: [identificador], onUpdate: NoAction, map: "fk_productos_duenios")
  empleados              empleados               @relation(fields: [revisor], references: [identificador], onUpdate: NoAction, map: "fk_productos_empleados")
  seguros                seguros?                @relation(fields: [seguro], references: [nroPoliza], onDelete: NoAction, onUpdate: NoAction, map: "fk_productos_seguros")
  registroDeSubasta      registroDeSubasta[]
}

model extra_solicitudesVenta {
  identificador      Int       @id(map: "pk_extra_solicitudesVenta") @default(autoincrement())
  cliente            Int
  producto           Int       @unique(map: "uq_extra_solicitudesVenta_producto")
  estado             String    @default("pendiente", map: "DF__extra_sol__estad__690797E6") @db.VarChar(20)
  categoria          String    @db.VarChar(50)
  precioBase         Decimal?  @db.Decimal(18, 2)
  comision           Decimal?  @db.Decimal(18, 2)
  motivo             String?   @db.VarChar(500)
  fechaSolicitud     DateTime  @default(now(), map: "DF__extra_sol__fecha__69FBBC1F")
  fechaActualizacion DateTime?
  clientes           clientes  @relation(fields: [cliente], references: [identificador], onUpdate: NoAction, map: "fk_extra_solicitudesVenta_clientes")
  productos          productos @relation(fields: [producto], references: [identificador], onUpdate: NoAction, map: "fk_extra_solicitudesVenta_productos")
}

model pujos {
  identificador Int           @id(map: "pk_pujos") @default(autoincrement())
  asistente     Int
  item          Int
  importe       Decimal       @db.Decimal(18, 2)
  ganador       String?       @default("no", map: "DF__pujos__ganador__2EDAF651") @db.VarChar(2)
  asistentes    asistentes    @relation(fields: [asistente], references: [identificador], onUpdate: NoAction, map: "fk_pujos_asistentes")
  itemsCatalogo itemsCatalogo @relation(fields: [item], references: [identificador], onUpdate: NoAction, map: "fk_pujos_itemsCatalogo")
}

model registroDeSubasta {
  identificador           Int                      @id(map: "pk_registroDeSubasta") @default(autoincrement())
  subasta                 Int
  duenio                  Int
  producto                Int
  cliente                 Int
  importe                 Decimal                  @db.Decimal(18, 2)
  comision                Decimal                  @db.Decimal(18, 2)
  extra_registroDeSubasta extra_registroDeSubasta?
  clientes                clientes                 @relation(fields: [cliente], references: [identificador], onUpdate: NoAction, map: "fk_registroDeSubasta_cliente")
  duenios                 duenios                  @relation(fields: [duenio], references: [identificador], onUpdate: NoAction, map: "fk_registroDeSubasta_duenios")
  productos               productos                @relation(fields: [producto], references: [identificador], onUpdate: NoAction, map: "fk_registroDeSubasta_producto")
  subastas                subastas                 @relation(fields: [subasta], references: [identificador], onUpdate: NoAction, map: "fk_registroDeSubasta_subastas")
}

model sectores {
  identificador     Int        @id(map: "pk_sectores") @default(autoincrement())
  nombreSector      String     @db.VarChar(150)
  codigoSector      String?    @db.VarChar(10)
  responsableSector Int?
  empleados         empleados? @relation(fields: [responsableSector], references: [identificador], onDelete: NoAction, onUpdate: NoAction, map: "fk_sectores_empleados")
}

model seguros {
  nroPoliza       String      @id(map: "pk_seguro") @db.VarChar(30)
  compania        String      @db.VarChar(150)
  polizaCombinada String?     @db.VarChar(2)
  importe         Decimal     @db.Decimal(18, 2)
  productos       productos[]
}

model subastadores {
  identificador Int        @id(map: "pk_subastadores")
  matricula     String?    @db.VarChar(15)
  region        String?    @db.VarChar(50)
  personas      personas   @relation(fields: [identificador], references: [identificador], onUpdate: NoAction, map: "fk_subastadores_personas")
  subastas      subastas[]
}

model subastas {
  identificador       Int                 @id(map: "pk_subastas") @default(autoincrement())
  fecha               DateTime?           @db.Date
  hora                DateTime            @db.Time
  estado              String?             @db.VarChar(10)
  subastador          Int?
  ubicacion           String?             @db.VarChar(350)
  capacidadAsistentes Int?
  tieneDeposito       String?             @db.VarChar(2)
  seguridadPropia     String?             @db.VarChar(2)
  categoria           String?             @db.VarChar(10)
  asistentes          asistentes[]
  catalogos           catalogos[]
  extra_subastas      extra_subastas[]
  registroDeSubasta   registroDeSubasta[]
  subastadores        subastadores?       @relation(fields: [subastador], references: [identificador], onDelete: NoAction, onUpdate: NoAction, map: "fk_subastas_subastadores")
}

model notificaciones {
  id                   Int      @id(map: "pk_notificaciones") @default(autoincrement())
  identificadorPersona Int
  mensaje              String   @db.VarChar(500)
  leido                Boolean  @default(false, map: "DF__notificac__leido__5CA1C101")
  fecha                DateTime @default(now(), map: "DF__notificac__fecha__5D95E53A")
  personas             personas @relation(fields: [identificadorPersona], references: [identificador], onUpdate: NoAction, map: "fk_notificaciones_personas")
}

model extra_registroDeSubasta {
  registro          Int                @id(map: "pk_extra_registroDeSubasta")
  metodoPago        Int?
  costoEnvio        Decimal?           @db.Decimal(18, 2)
  estadoPago        String             @default("pendiente", map: "DF__extra_reg__estad__625A9A57") @db.VarChar(20)
  fechaPago         DateTime?
  extra_metodosPago extra_metodosPago? @relation(fields: [metodoPago], references: [identificador], onDelete: NoAction, onUpdate: NoAction, map: "fk_extra_registroDeSubasta_metodoPago")
  registroDeSubasta registroDeSubasta  @relation(fields: [registro], references: [identificador], onUpdate: NoAction, map: "fk_extra_registroDeSubasta_registro")
}
